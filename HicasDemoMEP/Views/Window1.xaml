<Window x:Class="HicasDemoMEP.Views.Window1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hicas MEP Demo - Tool Kiểm tra &amp; Xuất bản vẽ" 
        Height="450" Width="400" 
        WindowStartupLocation="CenterScreen">
    <Grid>
        <TabControl>
            <TabItem Header="1. QA/QC Pipe">
                <StackPanel Margin="15">
                    <Button Content="1. Quét Toàn Bộ Ống (Model)" Height="30" Command="{Binding ScanPipesCommand}"/>

                    <GroupBox Header="Kết quả thống kê" Margin="0,15,0,0" Padding="10">
                        <StackPanel>
                            <TextBlock Text="{Binding TotalPipesText}" Margin="0,5"/>
                            <TextBlock Text="{Binding TotalLengthText}" Margin="0,5"/>
                            <TextBlock Text="{Binding UnconnectedText}" Foreground="Red" FontWeight="Bold" Margin="0,5"/>
                        </StackPanel>
                    </GroupBox>

                    <Button Content="2. Highlight Ống Lỗi" Height="30" Margin="0,15,0,0" 
                            IsEnabled="{Binding IsHighlightEnabled}" 
                            Command="{Binding HighlightCommand}"/>
                </StackPanel>
            </TabItem>

            <TabItem Header="2. Auto Spool Sheet">
                <StackPanel Margin="15">
                    <TextBlock Text="Chức năng tạo bản vẽ tự động theo Bounding Box. Quét chọn ống để cắt khung 3D và ném vào Sheet." TextWrapping="Wrap" Margin="0,0,0,15"/>
                    <Button Content="Chọn Ống &amp; Tạo Bản Vẽ" Height="40" Command="{Binding CreateSheetCommand}"/>
                </StackPanel>
            </TabItem>

            <TabItem Header="3. Tìm Element ID">
                <StackPanel Margin="15">
                    <TextBlock Text="Nhập Element ID (Số nguyên):" Margin="0,0,0,5"/>
                    <TextBox Height="30" VerticalContentAlignment="Center" Margin="0,0,0,10" 
                             Text="{Binding ElementIdInput, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Content="Tìm &amp; Zoom tới đối tượng" Height="35" Command="{Binding FindIdCommand}"/>
                </StackPanel>
            </TabItem>

            <TabItem Header="4. Thông tin Element ">
                <GroupBox Header="Thông tin Element được chọn" Margin="0,10,0,0" Padding="10">
                    <StackPanel>
                        <Button Content="Chọn Ống để xem thông tin" Height="30" Command="{Binding PickInfoCommand}" Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding ElementDetailText}" TextWrapping="Wrap" Background="#F0F0F0" Padding="5"/>
                    </StackPanel>
                </GroupBox>
            </TabItem>
        </TabControl>
    </Grid>
</Window>