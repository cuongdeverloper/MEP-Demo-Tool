<Window x:Class="HicasDemoMEP.Views.Window1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hicas MEP — Demo Tool"
        Height="520" Width="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="{DynamicResource WindowBackgroundBrush}"
        FontFamily="Segoe UI"
        Foreground="{DynamicResource BodyTextBrush}">
    <Window.Resources>
        <LinearGradientBrush x:Key="WindowBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FFF7FAFC" Offset="0.0"/>
            <GradientStop Color="#FFFFFFFF" Offset="1.0"/>
        </LinearGradientBrush>

        <!-- Core colors -->
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#0B84FF"/>
        <SolidColorBrush x:Key="AccentDarkBrush" Color="#0666CC"/>
        <SolidColorBrush x:Key="HeaderTextBrush" Color="#111827"/>
        <SolidColorBrush x:Key="BodyTextBrush" Color="#0B1220"/>
        <SolidColorBrush x:Key="SubtleTextBrush" Color="#4B5563"/>

        <FontFamily x:Key="GlyphFont">Segoe MDL2 Assets</FontFamily>

        <!-- Buttons -->
        <Style TargetType="Button" x:Key="PrimaryButton">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentDarkBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="GhostButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource HeaderTextBrush}"/>
            <Setter Property="BorderBrush" Value="#22000000"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#12000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tab header -->
        <DataTemplate x:Key="TabHeaderTemplate">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="6,4">
                <TextBlock FontFamily="{StaticResource GlyphFont}" Text="{Binding Tag}" Foreground="{StaticResource AccentBrush}" FontSize="14" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding}" Foreground="{StaticResource HeaderTextBrush}" FontWeight="SemiBold"/>
            </StackPanel>
        </DataTemplate>

        <!-- Card -->
        <Style TargetType="Border" x:Key="Card">
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#11000000" BlurRadius="8" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SmallLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource SubtleTextBrush}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- Info text style (dark) -->
        <Style x:Key="InfoText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BodyTextBrush}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="Hicas MEP" FontSize="20" FontWeight="Bold" Foreground="{StaticResource HeaderTextBrush}"/>
                <TextBlock Text="QA/QC and Auto Spool Sheet — Tools for MEP" Foreground="{StaticResource SubtleTextBrush}" FontSize="12"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                <Button Style="{StaticResource GhostButton}" Click="OnHelpClicked">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="{StaticResource GlyphFont}" Text="&#xE897;" Margin="0,0,6,0" Foreground="{StaticResource AccentBrush}" />
                        <TextBlock Text="Help" Foreground="{StaticResource HeaderTextBrush}"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </DockPanel>

        <!-- Main card -->
        <Border Grid.Row="1" Style="{StaticResource Card}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.4*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <TabControl Grid.Column="0" Background="Transparent" BorderThickness="0" Padding="4">
                    <TabItem HeaderTemplate="{StaticResource TabHeaderTemplate}" Header="1. QA/QC Pipe" Tag="&#xE8FB;">
                        <StackPanel Margin="6">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Style="{StaticResource PrimaryButton}" Command="{Binding ScanPipesCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontFamily="{StaticResource GlyphFont}" Text="&#xE8A7;" Margin="0,0,8,0" Foreground="White"/>
                                        <TextBlock Text="Scan Pipes" Foreground="White"/>
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource GhostButton}" Command="{Binding HighlightCommand}" IsEnabled="{Binding IsHighlightEnabled}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontFamily="{StaticResource GlyphFont}" Text="&#xE8FB;" Margin="0,0,8,0" Foreground="{StaticResource AccentBrush}"/>
                                        <TextBlock Text="Highlight Errors" Foreground="{StaticResource HeaderTextBrush}"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <Separator Margin="0,10"/>

                            <StackPanel Orientation="Vertical" Margin="6">
                                <TextBlock Text="Statistics" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,6" Foreground="{StaticResource HeaderTextBrush}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <StackPanel Width="160">
                                        <TextBlock Style="{StaticResource SmallLabel}" Text="Total Pipes"/>
                                        <TextBlock Text="{Binding TotalPipesText}" FontWeight="Bold" FontSize="13" Style="{StaticResource InfoText}"/>
                                    </StackPanel>
                                    <StackPanel Width="160" Margin="10,0,0,0">
                                        <TextBlock Style="{StaticResource SmallLabel}" Text="Total Length"/>
                                        <TextBlock Text="{Binding TotalLengthText}" FontWeight="Bold" FontSize="13" Style="{StaticResource InfoText}"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Margin="0,10">
                                    <TextBlock Style="{StaticResource SmallLabel}" Text="Issues" />
                                    <TextBlock Text="{Binding UnconnectedText}" Foreground="#B91C1C" FontWeight="Bold" Margin="0,4"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </TabItem>

                    <TabItem HeaderTemplate="{StaticResource TabHeaderTemplate}" Header="2. Auto Spool Sheet" Tag="&#xE76C;">
                        <StackPanel Margin="6">
                            <TextBlock Text="Create spool sheets automatically from selected pipe groups. Select pipes in Revit then run to cut 3D views and place on sheets." TextWrapping="Wrap" Foreground="{StaticResource SubtleTextBrush}" Margin="0,0,0,8"/>
                            <Button Style="{StaticResource PrimaryButton}" Height="42" Command="{Binding CreateSheetCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="{StaticResource GlyphFont}" Text="&#xE8C8;" Margin="0,0,8,0" Foreground="White"/>
                                    <TextBlock Text="Select Pipes &amp; Create Sheets" Foreground="White"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </TabItem>

                    <TabItem HeaderTemplate="{StaticResource TabHeaderTemplate}" Header="3. Find Element ID" Tag="&#xE721;">
                        <StackPanel Margin="6">
                            <TextBlock Text="Enter an element id and click Find to zoom to it in the model." Foreground="{StaticResource SubtleTextBrush}" Margin="0,0,0,8"/>
                            <TextBox Height="34" VerticalContentAlignment="Center" Text="{Binding ElementIdInput, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                            <Button Style="{StaticResource GhostButton}" Height="36" Command="{Binding FindIdCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="{StaticResource GlyphFont}" Text="&#xE8A8;" Margin="0,0,8,0" Foreground="{StaticResource AccentBrush}"/>
                                    <TextBlock Text="Find &amp; Zoom" Foreground="{StaticResource HeaderTextBrush}"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </TabItem>

                    <TabItem HeaderTemplate="{StaticResource TabHeaderTemplate}" Header="4. Element Info" Tag="&#xE946;">
                        <StackPanel Margin="6">
                            <Button Style="{StaticResource GhostButton}" Height="34" Command="{Binding PickInfoCommand}" Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="{StaticResource GlyphFont}" Text="&#xE7B8;" Margin="0,0,8,0" Foreground="{StaticResource AccentBrush}"/>
                                    <TextBlock Text="Pick Pipe to Inspect" Foreground="{StaticResource HeaderTextBrush}"/>
                                </StackPanel>
                            </Button>

                            <Border Background="#FFF8F9FA" CornerRadius="6" Padding="8">
                                <TextBlock Text="{Binding ElementDetailText}" TextWrapping="Wrap" Foreground="{StaticResource BodyTextBrush}"/>
                            </Border>
                        </StackPanel>
                    </TabItem>
                </TabControl>

                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Top">
                    <Border Style="{StaticResource Card}" Background="#FFF7FAFC">
                        <StackPanel>
                            <TextBlock Text="Quick Actions" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{StaticResource HeaderTextBrush}"/>
                            <Button Style="{StaticResource PrimaryButton}" Command="{Binding ScanPipesCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="{StaticResource GlyphFont}" Text="&#xE8A7;" Margin="0,0,8,0" Foreground="White"/>
                                    <TextBlock Text="Run Full Scan" Foreground="White"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource GhostButton}" Command="{Binding HighlightCommand}" IsEnabled="{Binding IsHighlightEnabled}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="{StaticResource GlyphFont}" Text="&#xE8FB;" Margin="0,0,8,0" Foreground="{StaticResource AccentBrush}"/>
                                    <TextBlock Text="Select Issues" Foreground="{StaticResource HeaderTextBrush}"/>
                                </StackPanel>
                            </Button>

                            <Separator Margin="0,8"/>

                            <TextBlock Text="Status" Style="{StaticResource SmallLabel}" Margin="0,6,0,2"/>
                            <ProgressBar Height="8" Value="0" Minimum="0" Maximum="100" Foreground="{StaticResource AccentBrush}" Background="#EFEFF0"/>

                            <TextBlock Text="Ready" FontSize="12" Foreground="{StaticResource SubtleTextBrush}" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}" Background="#FFFFFFFF">
                        <StackPanel>
                            <TextBlock Text="Notes" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{StaticResource HeaderTextBrush}"/>
                            <TextBlock Text="• Use Scan to detect unconnected pipes." Foreground="{StaticResource SubtleTextBrush}" TextWrapping="Wrap" Margin="0,4"/>
                            <TextBlock Text="• Highlight will select detected problems in the model." Foreground="{StaticResource SubtleTextBrush}" TextWrapping="Wrap" Margin="0,4"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <TextBlock Text="v1.0" Foreground="{StaticResource SubtleTextBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <Button Style="{StaticResource GhostButton}" Click="OnCloseClicked">Close</Button>
        </StackPanel>
    </Grid>
</Window>